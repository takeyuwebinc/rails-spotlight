<%= form_with(model: @project, url: @project.new_record? ? admin_adr_management_engagement_projects_path(@engagement) : admin_adr_management_engagement_project_path(@engagement, @project), class: "space-y-6") do |form| %>
  <% if @project.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="text-sm text-red-700">
        <ul class="list-disc space-y-1 pl-5">
          <% @project.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "名前", class: "block text-sm font-medium text-zinc-700" %>
    <%= form.text_field :name, class: "mt-1 block w-full rounded-md border-zinc-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "例: Fabble保守開発2026年度" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= form.label :start_date, "開始日", class: "block text-sm font-medium text-zinc-700" %>
      <%= form.date_field :start_date, class: "mt-1 block w-full rounded-md border-zinc-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div>
      <%= form.label :end_date, "終了日", class: "block text-sm font-medium text-zinc-700" %>
      <%= form.date_field :end_date, class: "mt-1 block w-full rounded-md border-zinc-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
  </div>

  <div class="flex justify-end space-x-3">
    <%= link_to "キャンセル", admin_adr_management_engagement_path(@engagement), class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-zinc-900 shadow-sm ring-1 ring-inset ring-zinc-300 hover:bg-zinc-50" %>
    <%= form.submit @project.new_record? ? "作成" : "更新", class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 cursor-pointer" %>
  </div>
<% end %>
