<% content_for(:title) { "プロジェクト一覧" } %>

<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-zinc-900">プロジェクト一覧</h1>
    <p class="text-sm text-zinc-500">案件: <%= link_to @engagement.name, admin_adr_management_engagement_path(@engagement), class: "text-indigo-600 hover:text-indigo-900" %></p>
  </div>
  <%= link_to "新規作成", new_admin_adr_management_engagement_project_path(@engagement), class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-zinc-200">
    <tbody class="bg-white divide-y divide-zinc-200">
      <% @projects.each do |project| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-900"><%= project.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500"><%= project.start_date %>〜<%= project.end_date %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to "編集", edit_admin_adr_management_engagement_project_path(@engagement, project), class: "text-indigo-600 hover:text-indigo-900" %>
          </td>
        </tr>
      <% end %>
      <% if @projects.empty? %>
        <tr><td class="px-6 py-4 text-center text-sm text-zinc-500">プロジェクトがありません</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
