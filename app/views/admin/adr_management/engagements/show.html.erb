<% content_for(:title) { @engagement.name } %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-zinc-900"><%= @engagement.name %></h1>
  <p class="text-sm text-zinc-500">コード: <%= @engagement.code %> ／ クライアント: <%= link_to @engagement.client.name, admin_adr_management_client_path(@engagement.client), class: "text-indigo-600 hover:text-indigo-900" %></p>
  <% if @engagement.description.present? %>
    <p class="mt-2 text-sm text-zinc-700"><%= @engagement.description %></p>
  <% end %>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-zinc-200 flex justify-between items-center">
    <h2 class="text-lg font-medium text-zinc-900">ADR</h2>
    <%= link_to "ADR を登録", new_admin_adr_management_adr_path(engagement_id: @engagement.id), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>
  <table class="min-w-full divide-y divide-zinc-200">
    <thead class="bg-zinc-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-zinc-500 uppercase tracking-wider">番号</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-zinc-500 uppercase tracking-wider">タイトル</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-zinc-500 uppercase tracking-wider">ステータス</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-zinc-500 uppercase tracking-wider">決定日</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-zinc-200">
      <% @adrs.each do |adr| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium"><%= link_to adr.display_number, admin_adr_management_adr_path(adr), class: "text-indigo-600 hover:text-indigo-900" %></td>
          <td class="px-6 py-4 text-sm text-zinc-900"><%= adr.title %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500"><%= adr_status_label(adr.status) %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500"><%= adr.decided_on %></td>
        </tr>
      <% end %>
      <% if @adrs.empty? %>
        <tr><td colspan="4" class="px-6 py-4 text-center text-sm text-zinc-500">ADR がありません</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-zinc-200 flex justify-between items-center">
    <h2 class="text-lg font-medium text-zinc-900">プロジェクト</h2>
    <%= link_to "プロジェクトを作成", new_admin_adr_management_engagement_project_path(@engagement), class: "text-sm text-indigo-600 hover:text-indigo-900" %>
  </div>
  <table class="min-w-full divide-y divide-zinc-200">
    <tbody class="bg-white divide-y divide-zinc-200">
      <% @projects.each do |project| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-900"><%= project.name %></td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-zinc-500"><%= project.start_date %>〜<%= project.end_date %></td>
          <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
            <%= link_to "編集", edit_admin_adr_management_engagement_project_path(@engagement, project), class: "text-indigo-600 hover:text-indigo-900 mr-4" %>
            <% if project.adrs.any? %>
              <span class="text-zinc-400 cursor-not-allowed" title="ADR から参照されているため削除できません">削除</span>
            <% else %>
              <%= link_to "削除", admin_adr_management_engagement_project_path(@engagement, project), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "text-red-600 hover:text-red-900" %>
            <% end %>
          </td>
        </tr>
      <% end %>
      <% if @projects.empty? %>
        <tr><td class="px-6 py-4 text-center text-sm text-zinc-500">プロジェクトがありません</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="flex space-x-3">
  <%= link_to "編集", edit_admin_adr_management_engagement_path(@engagement), class: "rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" %>
  <% if @projects.empty? && @adrs.empty? %>
    <%= link_to "削除", admin_adr_management_engagement_path(@engagement), data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, class: "rounded-md bg-red-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500" %>
  <% end %>
  <%= link_to "一覧に戻る", admin_adr_management_engagements_path, class: "rounded-md bg-white px-3 py-2 text-sm font-semibold text-zinc-900 shadow-sm ring-1 ring-inset ring-zinc-300 hover:bg-zinc-50" %>
</div>
