<div id="<%= dom_id(pending_change) %>"
     class="rounded-lg border-2 <%= pending_change.pending? ? 'border-amber-400' : 'border-zinc-200 dark:border-zinc-700' %> bg-white dark:bg-zinc-800 p-4">
  <div class="flex items-center justify-between mb-3">
    <div class="text-sm font-bold text-zinc-900 dark:text-zinc-100">
      提案 #<%= pending_change.id %>:
      <%= pending_change.target_type %> の<%= pending_change_operation_label(pending_change) %>
      <% if pending_change.target_id.present? %>
        <span class="text-zinc-500">（#<%= pending_change.target_id %>）</span>
      <% end %>
    </div>
    <span class="rounded-full px-2 py-0.5 text-xs font-medium <%= pending_change_status_badge_class(pending_change) %>">
      <%= pending_change_status_label(pending_change) %>
    </span>
  </div>

  <% rows = pending_change_rows(pending_change) %>
  <% if rows.any? %>
    <table class="w-full text-sm mb-3">
      <thead>
        <tr class="text-left text-xs text-zinc-500">
          <th class="py-1 pr-2">属性</th>
          <% unless pending_change.operation_create? %><th class="py-1 pr-2">現在値</th><% end %>
          <th class="py-1">提案値</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-100 dark:divide-zinc-700">
        <% rows.each do |row| %>
          <tr class="<%= 'bg-amber-50 dark:bg-amber-900/20' if row[:publication] %>">
            <td class="py-1 pr-2 font-mono text-xs text-zinc-500">
              <%= row[:key] %><%= "（公開状態）" if row[:publication] %>
            </td>
            <% unless pending_change.operation_create? %>
              <td class="py-1 pr-2 text-zinc-500"><%= row[:current] %></td>
            <% end %>
            <td class="py-1 text-zinc-900 dark:text-zinc-100"><%= row[:proposed] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>

  <% if pending_change.payload["tags"].present? %>
    <p class="text-sm mb-3 text-zinc-700 dark:text-zinc-300">
      タグ: <%= Array(pending_change.payload["tags"]).join(", ") %>
    </p>
  <% end %>

  <% if pending_change.payload["content"].present? %>
    <details class="mb-3 text-sm">
      <summary class="cursor-pointer text-zinc-600 dark:text-zinc-300">markdown 全文を表示</summary>
      <pre class="mt-1 overflow-x-auto rounded bg-zinc-100 dark:bg-zinc-900 p-2 max-h-64 text-xs"><%= pending_change.payload["content"] %></pre>
    </details>
  <% end %>

  <% if pending_change.failed? && pending_change.apply_error.present? %>
    <p class="text-sm text-red-700 dark:text-red-300 mb-3">適用エラー: <%= pending_change.apply_error %></p>
  <% end %>

  <% if pending_change.pending? %>
    <div class="flex gap-2">
      <%= button_to "承認して適用", admin_pending_change_approval_path(pending_change),
          class: "rounded-md bg-green-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-green-500" %>
      <%= button_to "否認", admin_pending_change_rejection_path(pending_change),
          class: "rounded-md border border-zinc-300 dark:border-zinc-600 px-3 py-1.5 text-sm font-medium text-zinc-700 dark:text-zinc-200 hover:bg-zinc-100 dark:hover:bg-zinc-700" %>
    </div>
    <p class="mt-2 text-xs text-zinc-500">承認するまでデータベースは変更されません。修正したい場合はチャットで指示してください。</p>
  <% end %>
</div>
